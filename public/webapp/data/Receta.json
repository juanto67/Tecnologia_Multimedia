            "description": "Guiso/ensalada templada de verduras fritas (berenjena, patata, pimiento) con salsa de tomate. Un clásico veraniego.",
            "prepTime": "PT30M",
            "cookTime": "PT40M",
            "totalTime": "PT1H10M",
            "recipeYield": "4 raciones",
            "recipeCategory": "Plato principal",
            "recipeCuisine": "Mallorquina",
            "keywords": "mallorca, tumbet, verduras, berenjena, tomate",
            "recipeIngredient": [
                "2 berenjenas",
                "2 patatas grandes",
                "2 pimientos rojos (o 1 rojo y 1 verde)",
                "4 tomates maduros (o 400 g de tomate triturado)",
                "2 dientes de ajo",
                "1 hoja de laurel",
                "Azúcar (una pizca para corregir acidez, opcional)",
                "Aceite de oliva (para freír y para la salsa)",
                "Sal",
                "Pimienta (opcional)"
            ],
            "recipeInstructions": [
                {
                    "@type": "HowToStep",
                    "text": "Corta las patatas en rodajas y fríelas hasta que estén tiernas; escurre y sala."
                },
                {
                    "@type": "HowToStep",
                    "text": "Corta las berenjenas en rodajas, fríelas y escurre; sala."
                },
                {
                    "@type": "HowToStep",
                    "text": "Asa o fríe los pimientos en tiras; escurre y reserva."
                },
                {
                    "@type": "HowToStep",
                    "text": "Prepara una salsa sofriendo el ajo y añadiendo el tomate; cocina 15–20 min y ajusta de sal."
                },
                {
                    "@type": "HowToStep",
                    "text": "Monta en una fuente capas de patata, berenjena y pimiento; cubre con la salsa de tomate."
                }
            ]
