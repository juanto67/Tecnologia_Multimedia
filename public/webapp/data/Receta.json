            "recipeInstructions": [
                {
                    "@type": "HowToStep",
                    "text": "Precalienta el horno a 200 °C."
                },
                {
                    "@type": "HowToStep",
                    "text": "Mezcla harina, agua, aceite y sal; amasa lo justo y estira la masa en una bandeja."
                },
                {
                    "@type": "HowToStep",
                    "text": "Pica tomate, pimiento y cebolla; aliña con aceite y sal (trampó)."
                },
                {
                    "@type": "HowToStep",
                    "text": "Reparte el trampó sobre la masa y hornea 25–30 min, hasta que la base esté hecha."
                }
