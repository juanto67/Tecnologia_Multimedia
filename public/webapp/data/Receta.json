            "datePublished": "2026-03-03",
            "description": "Dulce emblemático de Mallorca elaborado con masa enriquecida y manteca de cerdo (saïm).",
            "prepTime": "PT40M",
            "cookTime": "PT20M",
            "totalTime": "PT1H",
            "recipeYield": "1 ensaimada mediana",
            "recipeCategory": "Postre",
            "recipeCuisine": "Mallorquina",
            "keywords": "mallorca, ensaimada, repostería, dulce",
            "recipeIngredient": [
                "300 g de harina de fuerza",
                "60 g de azúcar",
                "2 huevos",
                "120 ml de leche templada",
                "7 g de levadura seca de panadería (o 20 g fresca)",
                "1 pizca de sal",
                "1 cucharadita de agua de azahar (opcional)",
                "1 cucharada de mantequilla (opcional)",
                "Manteca de cerdo (saïm), para untar",
                "Azúcar glas, para espolvorear"
            ],
            "recipeInstructions": [
                {
                    "@type": "HowToStep",
                    "text": "Disuelve la levadura en la leche templada. Mezcla con harina, azúcar, huevos y sal; amasa hasta lograr una masa elástica."
                },
                {
                    "@type": "HowToStep",
                    "text": "Deja fermentar tapada hasta que doble volumen (el tiempo depende de la temperatura)."
                },
                {
                    "@type": "HowToStep",
                    "text": "Estira la masa muy fina, unta con manteca y enrolla formando un cilindro; luego forma una espiral dejando separación para que crezca."
                },
                {
                    "@type": "HowToStep",
                    "text": "Deja una segunda fermentación hasta que aumente notablemente."
                },
                {
                    "@type": "HowToStep",
                    "text": "Hornea a 180 °C 15–20 min, hasta dorar. Enfría y espolvorea azúcar glas."
                }
            ]
        },
