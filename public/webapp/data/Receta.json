            "description": "Pan con tomate y aceite de oliva, acompañado de embutidos y/o queso. Sencillo y muy típico en Mallorca.",
            "prepTime": "PT10M",
            "cookTime": "PT0M",
            "totalTime": "PT10M",
            "recipeYield": "2 raciones",
            "recipeCategory": "Entrante",
            "recipeCuisine": "Mallorquina",
