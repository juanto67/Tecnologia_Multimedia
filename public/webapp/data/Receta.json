                "4 rebanadas de pan payés (o pan moreno)",
                "2 tomates de colgar (o tomates maduros)",
                "Aceite de oliva virgen extra",
                "Sal",
                "Aceitunas (opcional)",
                "Pepinillos (opcional)",
                "Opcional: sobrasada", 
                "Opcional: jamón serrano",
                "Opcional: queso mahonés"
            ],
            "recipeInstructions": [
                {
                    "@type": "HowToStep",
                    "text": "Tuesta ligeramente el pan si lo prefieres."
                },
                {
                    "@type": "HowToStep",
                    "text": "Frota el tomate sobre el pan hasta impregnar la miga."
                },
                {
                    "@type": "HowToStep",
                    "text": "Añade sal y un buen chorro de aceite de oliva."
                },
                {
                    "@type": "HowToStep",
                    "text": "Sirve con sobrasada, jamón o queso, al gusto."
                }
            ]
